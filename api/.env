# ─── Symfony ──────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=changeme_dev_secret_replace_in_prod

# ─── Database ─────────────────────────────────────────────────────────────────
# Ustawione też w docker-compose.yml
DATABASE_URL="mysql://root:secret@mysql:3306/aniarozgotuje?serverVersion=8.0&charset=utf8mb4"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_this_passphrase

# ─── Mailer ───────────────────────────────────────────────────────────────────
MAILER_DSN=smtp://mailpit:1025
